<script>
const DATA = JSON.parse(document.getElementById('data').textContent);
const {lib, cats, errors, groups, groupCss, templates} = DATA;
const byId = Object.fromEntries(lib.map(r=>[r.id,r]));
const catNames = Object.keys(cats).sort((a,b)=>cats[b].length-cats[a].length);
let currentCat = null;
document.getElementById('stats').textContent = lib.length + ' rules · ' + catNames.length + ' categories';

function esc(s){const d=document.createElement('div');d.textContent=s==null?'':String(s);return d.innerHTML;}

// ---------- NAV (event delegation, no inline handlers) ----------
const navEl = document.getElementById('nav');
function renderNav(){
  let h = '<div class="navcat'+(currentCat===null?' active':'')+'" data-act="home"><span>📚 All Rules (Library)</span><span class="n">'+lib.length+'</span></div>';
  catNames.forEach((c,i)=>{
    h += '<div class="navcat'+(currentCat===c?' active':'')+'" data-act="cat" data-ci="'+i+'"><span>'+esc(c)+'</span><span class="n">'+cats[c].length+'</span></div>';
  });
  navEl.innerHTML = h;
}
navEl.addEventListener('click', e=>{
  const el = e.target.closest('.navcat'); if(!el) return;
  if(el.dataset.act==='home') showHome();
  else showCat(catNames[+el.dataset.ci]);
});

// ---------- MAIN (event delegation) ----------
const mainEl = document.getElementById('main');
mainEl.addEventListener('click', e=>{
  const rc = e.target.closest('[data-rule]');
  if(rc){ showRule(+rc.dataset.rule); return; }
  const cc = e.target.closest('[data-goto-cat]');
  if(cc){ showCat(catNames[+cc.dataset.gotoCat]); return; }
  const hm = e.target.closest('[data-goto-home]');
  if(hm){ showHome(); return; }
});

function ruleCard(r){
  if(!r) return '';
  return '<div class="rulecard" data-rule="'+r.id+'"><div class="sel" style="display:flex;justify-content:space-between;align-items:center;gap:10px"><span>'+esc(r.sel)+'</span><button class="delbtn" data-del="'+r.id+'" title="Delete">✕</button></div><div class="meta"><span class="tag">'+esc(r.cat)+'</span>'+(r.custom?'<span class="customtag">custom</span>':'')+(r.media?'<span class="tag media">'+esc(r.media)+'</span>':'')+'<span>line '+r.line+'</span></div></div>';
}
function catLink(c){ return '<a data-goto-cat="'+catNames.indexOf(c)+'">'+esc(c)+'</a>'; }

function showHome(){
  currentCat = null; renderNav();
  let h = '<h2 class="pagetitle">CSS Rule Library<span class="bar"></span></h2>';
  h += '<p class="desc">Every rule in <b>style.css</b> ('+lib.length+' rules, 6,457 lines), grouped by component. Click any rule for its detail page: how to use, what is included, full code, and a live component preview.</p>';
  if(errors.length){
    h += '<div class="errbox"><b>⚠ '+errors.length+' syntax issues found in style.css:</b><ul style="margin:8px 0 0;padding-left:20px">'+errors.map(x=>'<li>'+esc(x)+'</li>').join('')+'</ul></div>';
  }
  for(const c of catNames){
    h += '<h2 class="pagetitle" style="font-size:19px;margin-top:26px">'+esc(c)+' <span class="count">('+cats[c].length+')</span></h2>';
    h += cats[c].map(id=>ruleCard(byId[id])).join('');
  }
  setMain(h);
}
function showCat(c){
  currentCat = c; renderNav();
  let h = '<div class="crumb"><a data-goto-home="1">Library</a> / '+esc(c)+'</div>';
  h += '<h2 class="pagetitle">'+esc(c)+'<span class="bar"></span></h2>';
  h += '<p class="desc">'+cats[c].length+' rules in this category.</p>';
  h += cats[c].map(id=>ruleCard(byId[id])).join('');
  setMain(h);
  window.scrollTo(0,0);
}

// ---------- PREVIEW ----------
function heuristicMarkup(g){
  try{
    const ids = groups[g]||[];
    const sels = ids.map(i=>byId[i].sel.split(',')[0].trim());
    let rootSel = null;
    for(const s of sels){
      if(/^[#.][a-zA-Z0-9_-]+$/.test(s) && !s.includes('--') && !s.includes('__')){ rootSel = s; break; }
    }
    if(!rootSel){ const m = sels[0] && sels[0].match(/^[#.][a-zA-Z0-9_-]+/); rootSel = m ? m[0] : null; }
    if(!rootSel){
      if(g.indexOf('tag:')===0){
        const t = g.slice(4);
        if(t==='table') return '<table><tr><th>Header A</th><th>Header B</th></tr><tr><td>Cell</td><td>Cell</td></tr><tr><td>Cell</td><td>Cell</td></tr></table>';
        if(t==='input') return '<input type="text" value="Sample input"> <input type="submit" value="Submit">';
        if(t==='a') return '<a href="#">Sample link</a>';
        if(/^h[1-6]$/.test(t)) return '<'+t+'>Sample Heading</'+t+'>';
        if(t==='ul'||t==='ol') return '<'+t+'><li>Item one</li><li>Item two</li></'+t+'>';
        if(t==='button') return '<button>Sample button</button>';
        if(t==='body'||t==='*'||t==='html') return '<p>Sample body text — a paragraph of content with a <a href="#">link</a>.</p>';
        return '<'+t+'>Sample content</'+t+'>';
      }
      return '<div>Sample content</div>';
    }
    const rootName = rootSel.slice(1);
    const base = rootName.split('__')[0];
    const mods = new Set(), children = new Map();
    const tagFor = s => /__link|-link/.test(s)?'a' : /button|btn|__copy|-copy/.test(s)?'button' : /input/.test(s)?'input' : /__title|-title|heading/.test(s)?'h3' : 'div';
    const reMod = new RegExp('^[#.]'+base+'(--[a-zA-Z0-9-]+)$');
    const reBem = new RegExp('[#.]'+base+'(__[a-zA-Z0-9_-]+)');
    const reDesc = new RegExp('^[#.]'+rootName+'[ >]+\.([a-zA-Z0-9_-]+)');
    for(const s of sels){
      let m = s.match(reMod); if(m){ mods.add(base+m[1]); continue; }
      m = s.match(reBem); if(m){ const n=base+m[1]; if(!children.has(n)) children.set(n, tagFor(s)); continue; }
      m = s.match(reDesc); if(m){ if(!children.has(m[1])) children.set(m[1], tagFor(s)); continue; }
      m = s.match(/^[.]([a-zA-Z0-9_-]+)/);
      if(m && m[1]!==rootName && m[1].indexOf(g)===0 && !children.has(m[1])) children.set(m[1], tagFor(s));
    }
    let inner='', i=0;
    const SAMPLES=['Sample title','Sample text content for this element.','Another line of sample content.','Action','More info'];
    for(const [name, tag] of children){
      const txt = SAMPLES[Math.min(i, SAMPLES.length-1)]; i++;
      if(tag==='a') inner += '<a class="'+name+'" href="#">'+txt+'</a>';
      else if(tag==='button') inner += '<button class="'+name+'">'+txt+'</button>';
      else if(tag==='input') inner += '<input class="'+name+'" type="text" value="Sample">';
      else if(tag==='h3') inner += '<h3 class="'+name+'">'+txt+'</h3>';
      else inner += '<div class="'+name+'">'+txt+'</div>';
      if(i>8) break;
    }
    if(!inner) inner='Sample content';
    if(rootSel[0]==='#') return '<div id="'+rootName+'" class="'+[...mods].join(' ')+'">'+inner+'</div>';
    return '<div class="'+rootName+(mods.size?' '+[...mods].join(' '):'')+'">'+inner+'</div>';
  }catch(err){ return '<div>Sample content</div>'; }
}

function componentPreview(r){
  try{
    if(r.sel.indexOf('@import')===0 || r.sel.indexOf('@charset')===0) return null;
    const g = r.group;
    let css, html, note;
    if(r.sel.indexOf('@keyframes')===0){
      const name = r.sel.replace('@keyframes','').trim();
      html = '<div class="kf-demo">'+name+'</div>';
      css = r.code + '\n.kf-demo{width:100px;height:100px;background:#e8562a;color:#fff;display:flex;align-items:center;justify-content:center;border-radius:12px;font-size:11px;animation:'+name+' 2s infinite;}';
      return {css, html, note:'Demo box running <code>'+esc(name)+'</code> on loop.'};
    }
    css = groupCss[g] || r.code;
    html = templates[g] || heuristicMarkup(g);
    let hi = '';
    const target = r.sel.split(',')[0].replace(/::?(hover|focus|active|before|after|focus-visible|placeholder)[^ >]*/g,'').trim();
    if(target && !/[{}@]/.test(target)) hi = target+'{outline:2px dashed #e8562a; outline-offset:3px;}';
    note = 'The whole <b>'+esc(g)+'</b> component is rendered with all '+((groups[g]||[]).length)+' of its rules applied together. The element this rule targets is outlined in <span style="color:#e8562a;font-weight:700">orange dashes</span>.';
    if(/:(hover|focus|active)/.test(r.sel)) note += ' This rule is an interaction state — hover/click the outlined element to trigger it.';
    if(r.media) note += ' Media conditions are stripped in the preview; live breakpoint: <code>'+esc(r.media)+'</code>.';
    return {css: css+'\n'+hi, html, note};
  }catch(err){ return null; }
}

function mountPreview(r){
  const holder = document.getElementById('pvholder');
  if(!holder) return;
  const p = componentPreview(r);
  if(!p){ holder.parentElement.style.display='none'; return; }
  document.getElementById('pvnote').innerHTML = p.note;
  const iframe = document.createElement('iframe');
  iframe.className = 'pv';
  iframe.setAttribute('sandbox','allow-same-origin');
  holder.innerHTML = '';
  holder.appendChild(iframe);
  // write the doc programmatically — no attribute escaping issues, no matter what's in the CSS
  const doc = iframe.contentDocument;
  doc.open();
  doc.write('<!DOCTYPE html><html><head><link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..900&family=DM+Mono:wght@400;500&family=Poppins:wght@600;700&display=swap" rel="stylesheet"></head><body></body></html>');
  doc.close();
  const st = doc.createElement('style');
  st.textContent = 'body{font-family:"DM Sans",sans-serif;padding:24px;margin:0;background:#f6f5f2;color:#171a21;font-size:15px;line-height:1.5}' + p.css;
  doc.head.appendChild(st);
  doc.body.innerHTML = p.html;
}

function showRule(id){
  const r = byId[id];
  let h = '<div class="crumb"><a data-goto-home="1">Library</a> / '+catLink(r.cat)+'</div>';
  h += '<button class="backbtn" data-goto-cat="'+catNames.indexOf(r.cat)+'">← Back</button><button class="delbtn" data-del="'+r.id+'" style="vertical-align:top;padding:8px 16px">Delete rule</button>';
  h += '<div class="detail"><h2 class="pagetitle">'+esc(r.sel)+'<span class="bar"></span></h2>';
  h += '<p class="desc">Category: <b>'+esc(r.cat)+'</b> · Component group: <b>'+esc(r.group)+'</b> · style.css line <b>'+r.line+'</b>'+(r.media?' · scoped to <b>'+esc(r.media)+'</b>':'')+(r.comment?' · nearest comment: “'+esc(r.comment)+'”':'')+'</p>';
  h += '<div class="section"><h3>How to use</h3><p>'+r.use+'</p></div>';
  if(r.props && r.props.length){
    h += '<div class="section"><h3>What is included ('+r.props.length+' properties)</h3><table class="props"><tr><th>Property</th><th>Value</th><th>What it does</th></tr>';
    h += r.props.map(p=>'<tr><td class="p">'+esc(p.p)+'</td><td class="v">'+esc(p.v)+'</td><td class="d">'+esc(p.d||describeProp(p.p)||'—')+'</td></tr>').join('');
    h += '</table></div>';
  }
  h += '<div class="section"><h3>Full code</h3><pre>'+esc(r.code)+'</pre></div>';
  h += '<div class="section"><h3>How it looks — full component</h3><p id="pvnote" style="margin-bottom:10px;font-size:13px;color:var(--muted)"></p><div id="pvholder"></div><p style="margin-top:8px;font-size:12px;color:var(--muted)">Preview uses component markup + every rule in this component group. Zendesk base-theme styles aren\'t present, so spacing/fonts may differ slightly from the live KB.</p></div>';
  h += '</div>';
  setMain(h);
  mountPreview(r);
  window.scrollTo(0,0);
}
function setMain(h){ mainEl.innerHTML = h; }

document.getElementById('q').addEventListener('input', e=>{
  const q = e.target.value.trim().toLowerCase();
  if(!q){ showHome(); return; }
  const hits = Object.values(byId).filter(r => r.sel.toLowerCase().includes(q) || r.code.toLowerCase().includes(q));
  let h = '<h2 class="pagetitle">Search: “'+esc(q)+'”<span class="bar"></span></h2><p class="desc">'+hits.length+' matching rules.</p>';
  h += hits.slice(0,200).map(ruleCard).join('');
  if(hits.length>200) h += '<p class="desc">Showing first 200 — refine the search.</p>';
  setMain(h);
});


// ================= CUSTOM RULES: ADD / DELETE / VALIDATE =================
const STORE_KEY = 'bz-css-lib-custom-v1';
function loadStore(){ try{ return JSON.parse(localStorage.getItem(STORE_KEY)) || {added:[],deleted:[]}; }catch(e){ return {added:[],deleted:[]}; } }
function saveStore(s){ try{ localStorage.setItem(STORE_KEY, JSON.stringify(s)); }catch(e){ alert('Could not save — browser storage unavailable. Changes will be lost on reload.'); } }
let store = loadStore();

function applyStore(){
  // deletions
  for(const id of store.deleted){
    const r = byId[id]; if(!r) continue;
    const arr = cats[r.cat]; const i = arr ? arr.indexOf(id) : -1;
    if(i>-1) arr.splice(i,1);
    const gi = (groups[r.group]||[]).indexOf(id);
    if(gi>-1) groups[r.group].splice(gi,1);
    delete byId[id];
  }
  // additions
  for(const r of store.added){
    byId[r.id] = r;
    if(!cats[r.cat]) { cats[r.cat] = []; if(!catNames.includes(r.cat)) catNames.push(r.cat); }
    if(!cats[r.cat].includes(r.id)) cats[r.cat].push(r.id);
    if(!groups[r.group]) groups[r.group] = [];
    if(!groups[r.group].includes(r.id)) groups[r.group].push(r.id);
    groupCss[r.group] = (groupCss[r.group]||'') + '\n' + r.code;
  }
  document.getElementById('stats').textContent = Object.keys(byId).length + ' rules · ' + catNames.length + ' categories';
}

// ---------- CSS LINTER ----------
const KNOWN_PSEUDO = /^(hover|focus|active|visited|link|before|after|first-child|last-child|first-of-type|last-of-type|nth-child|nth-of-type|not|is|where|has|checked|disabled|enabled|placeholder|focus-visible|focus-within|root|empty|target|only-child|selection|marker|first-line|first-letter)/;
function lintCSS(text){
  const errs = [], warns = [];
  if(!text.trim()){ return {errs:['Nothing to check yet.'], warns, rules:[]}; }
  // brace balance with line tracking
  let depth = 0, line = 1, inC = false, inStr = null;
  for(let i=0;i<text.length;i++){
    const ch = text[i];
    if(ch === '\n') line++;
    if(inC){ if(ch==='*' && text[i+1]==='/'){ inC=false; i++; } continue; }
    if(inStr){ if(ch===inStr && text[i-1]!=='\\') inStr=null; continue; }
    if(ch==='/' && text[i+1]==='*'){ inC=true; i++; continue; }
    if(ch==='"'||ch==="'"){ inStr=ch; continue; }
    if(ch==='{') depth++;
    if(ch==='}'){ depth--; if(depth<0){ errs.push('Extra closing brace } at line '+line); depth=0; } }
  }
  if(inC) errs.push('Unclosed comment /* ... — everything after it is ignored by the browser');
  if(depth>0) errs.push(depth+' unclosed brace'+(depth>1?'s':'')+' — missing }');

  // parse rules
  const rules = [];
  const clean = text.replace(/\/\*[\s\S]*?\*\//g, m=>m.replace(/[^\n]/g,' '));
  const re = /([^{}]+)\{([^{}]*)\}/g;
  let m;
  while((m = re.exec(clean))){
    const sel = m[1].trim(); const body = m[2];
    if(!sel) { errs.push('A rule has an empty selector before {'); continue; }
    if(sel.startsWith('@media')||sel.startsWith('@supports')){ warns.push('Nested @media detected — the checker validates the inner rules only partially. Selector: '+sel.slice(0,50)); continue; }
    if(sel.startsWith('@keyframes')||sel.startsWith('@font-face')){ rules.push({sel, body, at:true}); continue; }
    // selector validity
    try { document.createDocumentFragment().querySelector(sel.replace(/::?[a-zA-Z-]+(\([^)]*\))?/g,'')); }
    catch(e){ errs.push('Invalid selector: "'+sel.slice(0,60)+'"'); }
    // unknown pseudo check
    const ps = [...sel.matchAll(/::?([a-zA-Z-]+)/g)];
    for(const p of ps){ if(!KNOWN_PSEUDO.test(p[1])) warns.push('Unrecognized pseudo ":'+p[1]+'" in "'+sel.slice(0,40)+'"'); }
    // declarations
    if(!body.trim()){ warns.push('Empty rule (no properties): "'+sel.slice(0,50)+'" — like the #bz-jump-panel bug at line 5829'); }
    const decls = body.split(';');
    for(let dRaw of decls){
      const d = dRaw.trim(); if(!d) continue;
      if(!d.includes(':')){ errs.push('Missing ":" in declaration "'+d.slice(0,40)+'" inside "'+sel.slice(0,35)+'" (or a missing ";" on the line before)'); continue; }
      const ci = d.indexOf(':');
      const prop = d.slice(0,ci).trim(); const val = d.slice(ci+1).trim().replace(/!important\s*$/,'').trim();
      if(!val){ errs.push('Empty value for "'+prop+'" in "'+sel.slice(0,35)+'"'); continue; }
      if(/^\$/.test(val) || val.includes('$')){ warns.push('"'+prop+': '+val+'" uses a $variable — fine in the Zendesk theme, but won\'t render in the preview'); continue; }
      if(/^--/.test(prop)) continue; // custom property, always valid
      if(window.CSS && CSS.supports){
        if(!CSS.supports(prop, val)){
          if(!CSS.supports(prop, 'initial')) errs.push('Unknown property "'+prop+'" in "'+sel.slice(0,35)+'" — typo?');
          else errs.push('Invalid value "'+val.slice(0,40)+'" for "'+prop+'" in "'+sel.slice(0,35)+'"');
        }
      }
    }
    // missing final semicolon is legal CSS; but detect two decls jammed together: "color:red font-weight:700"
    rules.push({sel, body});
  }
  if(!errs.length && !rules.length && text.trim()) errs.push('No complete rule found — expected: selector { property: value; }');
  return {errs, warns, rules};
}

// ---------- ADD MODAL ----------
const modalbg = document.getElementById('modalbg');
const addcss = document.getElementById('addcss');
const lintbox = document.getElementById('lintbox');
const msave = document.getElementById('msave');
const addcat = document.getElementById('addcat');

function openModal(){
  addcat.innerHTML = '<option value="">— Auto-detect category —</option>' + catNames.map((c,i)=>'<option value="'+i+'">'+esc(c)+'</option>').join('');
  addcss.value=''; lintbox.className='lint'; lintbox.innerHTML=''; msave.disabled=true;
  modalbg.classList.add('open'); addcss.focus();
}
document.getElementById('addRuleBtn').addEventListener('click', openModal);
document.getElementById('mcancel').addEventListener('click', ()=>modalbg.classList.remove('open'));
modalbg.addEventListener('click', e=>{ if(e.target===modalbg) modalbg.classList.remove('open'); });

let lintTimer = null;
addcss.addEventListener('input', ()=>{ clearTimeout(lintTimer); lintTimer = setTimeout(runLint, 250); });
function runLint(){
  const res = lintCSS(addcss.value);
  if(!addcss.value.trim()){ lintbox.className='lint'; msave.disabled=true; return; }
  if(res.errs.length){
    lintbox.className='lint err';
    lintbox.innerHTML = '<b class="e">✕ '+res.errs.length+' error'+(res.errs.length>1?'s':'')+' — fix before saving:</b><ul>'+res.errs.map(x=>'<li class="e">'+esc(x)+'</li>').join('')+(res.warns.length?res.warns.map(x=>'<li class="w">⚠ '+esc(x)+'</li>').join(''):'')+'</ul>';
    msave.disabled = true;
  } else if(res.warns.length){
    lintbox.className='lint warn';
    lintbox.innerHTML = '<b class="w">⚠ Valid, with '+res.warns.length+' warning'+(res.warns.length>1?'s':'')+':</b><ul>'+res.warns.map(x=>'<li class="w">'+esc(x)+'</li>').join('')+'</ul>';
    msave.disabled = false;
  } else {
    lintbox.className='lint ok';
    lintbox.innerHTML = '✓ Valid CSS — '+res.rules.length+' rule'+(res.rules.length>1?'s':'')+' ready to add.';
    msave.disabled = false;
  }
  return res;
}

function jsHowToUse(sel, body){
  const first = sel.split(',')[0].trim();
  const bits = [];
  const id = (first.match(/#([a-zA-Z0-9_-]+)/)||[])[1];
  const cls = [...first.matchAll(/\.([a-zA-Z0-9_-]+)/g)].map(x=>x[1]);
  if(id) bits.push('Targets the unique element <code>id="'+id+'"</code> (one per page).');
  else if(cls.length){
    if(/[ >]/.test(first)) bits.push('Applies to <code>'+cls[cls.length-1]+'</code> elements inside a <code>'+(cls[0]||first.split(/\s/)[0])+'</code> container.');
    else bits.push('Add <code>class="'+cls[0]+'"</code> to an HTML element.');
  } else { const t=first.split(':')[0].trim(); if(t) bits.push('Automatically styles every <code>&lt;'+t+'&gt;</code> element — no class needed.'); }
  const st = first.match(/:(hover|focus|active)/); if(st) bits.push('Only active on <b>'+st[1]+'</b>.');
  if(sel.includes(',')) bits.push('Shared by '+sel.split(',').length+' selectors.');
  if(body.includes('!important')) bits.push('Uses <b>!important</b> — overrides theme defaults.');
  return bits.join(' ') || 'Custom rule.';
}

const PROP_DESC = {
 'display':'layout mode','position':'positioning scheme','background':'background fill','background-color':'background color',
 'background-image':'background image','background-size':'background image sizing','background-position':'background image position','background-repeat':'background tiling',
 'color':'text color','font-family':'typeface','font-size':'text size','font-weight':'text weight','font-style':'italic/normal','line-height':'line spacing',
 'margin':'outer spacing','margin-top':'outer spacing (top)','margin-bottom':'outer spacing (bottom)','margin-left':'outer spacing (left)','margin-right':'outer spacing (right)',
 'padding':'inner spacing','padding-top':'inner spacing (top)','padding-bottom':'inner spacing (bottom)','padding-left':'inner spacing (left)','padding-right':'inner spacing (right)',
 'border':'border','border-top':'top border','border-bottom':'bottom border','border-left':'left border','border-right':'right border',
 'border-radius':'corner rounding','border-color':'border color','border-width':'border thickness','border-style':'border line style','border-collapse':'table border model','border-spacing':'table cell gaps',
 'box-shadow':'drop/inner shadow','text-shadow':'text shadow',
 'width':'width','height':'height','max-width':'max width','min-width':'min width','max-height':'max height','min-height':'min height',
 'flex':'flex sizing','flex-direction':'flex axis direction','flex-wrap':'flex wrapping','flex-grow':'flex grow factor','flex-shrink':'flex shrink factor','flex-basis':'flex base size',
 'gap':'gap between children','row-gap':'gap between rows','column-gap':'gap between columns',
 'align-items':'cross-axis alignment','align-self':'own cross-axis alignment','align-content':'multi-line alignment','justify-content':'main-axis alignment','justify-items':'grid item alignment','justify-self':'own main-axis alignment',
 'grid-template-columns':'grid column layout','grid-template-rows':'grid row layout','grid-column':'grid column placement','grid-row':'grid row placement','grid-area':'grid area placement',
 'z-index':'stacking order','overflow':'overflow behavior','overflow-x':'horizontal overflow','overflow-y':'vertical overflow',
 'transition':'animated property changes','transition-delay':'transition delay','transition-duration':'transition length','animation':'keyframe animation','animation-delay':'animation delay','animation-duration':'animation length','animation-iteration-count':'animation repeats',
 'transform':'geometric transform','transform-origin':'transform pivot point','opacity':'transparency','cursor':'mouse cursor',
 'text-align':'text alignment','letter-spacing':'letter spacing','word-spacing':'word spacing','text-transform':'text casing','text-decoration':'text decoration','text-overflow':'text clipping style','text-indent':'first-line indent',
 'top':'offset top','left':'offset left','right':'offset right','bottom':'offset bottom','inset':'offsets (all sides)',
 'content':'generated content','visibility':'visibility','pointer-events':'click-through behavior','white-space':'whitespace handling','vertical-align':'inline vertical alignment',
 'object-fit':'image fit','object-position':'image position','filter':'visual filter','backdrop-filter':'backdrop blur/filter',
 'outline':'focus outline','outline-offset':'outline distance','list-style':'list markers','list-style-type':'list marker type',
 'box-sizing':'box model','float':'float','clear':'float clearing','order':'flex order','user-select':'text selectability',
 'scrollbar-width':'scrollbar style','scroll-behavior':'scroll animation','appearance':'native widget styling','resize':'user resizability','aspect-ratio':'width:height ratio',
 'font':'font shorthand','text-wrap':'text wrapping','word-break':'word breaking','overflow-wrap':'word wrap','hyphens':'hyphenation','will-change':'render optimization hint','clip-path':'clipping shape','mix-blend-mode':'color blending','isolation':'stacking context'
};
function describeProp(p){
  p = p.toLowerCase().replace(/^-(webkit|moz|ms|o)-/,'');
  return PROP_DESC[p] || '';
}

function jsProps(body){
  return body.split(';').map(s=>s.trim()).filter(s=>s && s.includes(':')).map(s=>{
    const i=s.indexOf(':'); const p=s.slice(0,i).trim(); return {p:p, v:s.slice(i+1).trim(), d:describeProp(p)};
  });
}
function jsGroup(sel){
  const m = sel.split(',')[0].trim().match(/^[#.]([a-zA-Z0-9_-]+)/);
  if(!m) return 'custom';
  let t = m[1].split('__')[0].split('--')[0];
  if(t.indexOf('fx-')===0) return 'fx';
  if(t.indexOf('bz-hero')===0) return 'bz-hero';
  if(t.indexOf('bz-jp')===0 || t.indexOf('bz-jump')===0) return 'bz-jump-panel';
  if(t.indexOf('bz-toc')===0) return 'bz-toc';
  return t;
}

let nextId = Math.max(...lib.map(r=>r.id), ...(store.added.map(r=>r.id)), 0) + 1;
msave.addEventListener('click', ()=>{
  const res = runLint();
  if(!res || res.errs.length) return;
  const catChoice = addcat.value === '' ? null : catNames[+addcat.value];
  const madeIds = [];
  for(const rule of res.rules){
    const g = jsGroup(rule.sel);
    const cat = catChoice || (function(){
      // simple auto-cat: reuse category of an existing rule in same group, else "Custom Rules"
      const sib = (groups[g]||[]).map(i=>byId[i]).find(Boolean);
      return sib ? sib.cat : 'Custom Rules';
    })();
    const r = {
      id: nextId++, sel: rule.sel.replace(/\s+/g,' '), cat, group: g, line: '(custom)', media: '',
      comment: 'Added via library', custom: true,
      code: rule.sel.replace(/\s+/g,' ')+' {\n'+rule.body.split(';').map(s=>s.trim()).filter(Boolean).map(s=>'  '+s+';').join('\n')+'\n}',
      use: jsHowToUse(rule.sel, rule.body),
      props: jsProps(rule.body)
    };
    store.added.push(r);
    madeIds.push(r.id);
  }
  saveStore(store);
  applyStore();
  modalbg.classList.remove('open');
  renderNav();
  if(madeIds.length===1) showRule(madeIds[0]); else showCat(byId[madeIds[0]].cat);
});

// ---------- DELETE ----------
function deleteRule(id){
  const r = byId[id]; if(!r) return;
  if(!confirm('Delete rule "'+r.sel.slice(0,60)+'" from the library?\n(Only removes it from this document, not from style.css)')) return;
  if(r.custom){ store.added = store.added.filter(x=>x.id!==id); }
  else { store.deleted.push(id); }
  saveStore(store);
  const arr = cats[r.cat]; const i = arr.indexOf(id); if(i>-1) arr.splice(i,1);
  const gi=(groups[r.group]||[]).indexOf(id); if(gi>-1) groups[r.group].splice(gi,1);
  delete byId[id];
  document.getElementById('stats').textContent = Object.keys(byId).length + ' rules · ' + catNames.length + ' categories';
  renderNav();
  if(currentCat) showCat(currentCat); else showHome();
}
mainEl.addEventListener('click', e=>{
  const del = e.target.closest('[data-del]');
  if(del){ e.stopPropagation(); deleteRule(+del.dataset.del); }
}, true);

applyStore();

renderNav(); showHome();
</script>
