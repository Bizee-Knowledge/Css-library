<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Bizee KB — CSS Rule Library</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--orange:#e8562a;--orange-soft:#fff3ef;--orange-line:#f5d0bf;--ink:#171a21;--card:#ffffff;--bg:#f6f5f2;--muted:#6b7280;--code-bg:#0f1117;--code-fg:#e5e9f0;}
*{box-sizing:border-box}
body{margin:0;font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--ink);font-size:15px}
.app{display:flex;min-height:100vh}
.side{width:290px;flex-shrink:0;background:#0f1117;color:#cfd6e4;position:sticky;top:0;height:100vh;overflow-y:auto}
.side h1{font-size:16px;font-weight:800;color:#fff;padding:18px 18px 4px;margin:0;letter-spacing:.3px}
.side h1 span{color:var(--orange)}
.side .sub{padding:0 18px 12px;font-size:12px;color:#7d8595}
.side input{width:calc(100% - 36px);margin:0 18px 12px;padding:8px 10px;border-radius:8px;border:1px solid #2a2f3a;background:#171b24;color:#fff;font-family:inherit;font-size:13px}
.side input:focus{outline:none;border-color:var(--orange)}
.navcat{padding:8px 18px;cursor:pointer;font-size:13.5px;display:flex;justify-content:space-between;align-items:center;border-left:3px solid transparent}
.navcat:hover{background:#171b24}
.navcat.active{background:#1b1f2a;border-left-color:var(--orange);color:#fff}
.navcat .n{background:#242a37;border-radius:10px;padding:1px 8px;font-size:11px;color:#9aa3b5}
.main{flex:1;padding:28px 36px;max-width:1000px}
.crumb{font-size:12.5px;color:var(--muted);margin-bottom:10px}
.crumb a{color:var(--orange);text-decoration:none;cursor:pointer}
[data-goto-cat],[data-goto-home]{cursor:pointer}
h2.pagetitle{font-size:26px;font-weight:800;margin:0 0 4px}
.pagetitle .bar{display:block;width:64px;height:4px;background:var(--orange);border-radius:2px;margin-top:8px}
.desc{color:var(--muted);margin:12px 0 22px;font-size:14px}
.rulecard{background:var(--card);border:1px solid #e7e5e0;border-radius:12px;padding:14px 18px;margin-bottom:12px;cursor:pointer;transition:box-shadow .15s,border-color .15s}
.rulecard:hover{border-color:var(--orange);box-shadow:0 4px 14px rgba(232,86,42,.12)}
.rulecard .sel{font-family:'DM Mono',monospace;font-weight:500;font-size:14px}
.rulecard .meta{font-size:12px;color:var(--muted);margin-top:4px;display:flex;gap:14px;flex-wrap:wrap}
.tag{background:var(--orange-soft);border:1px solid var(--orange-line);color:#b4451f;border-radius:10px;padding:1px 8px;font-size:11px}
.tag.media{background:#eef4ff;border-color:#c9d8f5;color:#3b5bab}
pre{background:var(--code-bg);color:var(--code-fg);padding:16px 18px;border-radius:12px;overflow-x:auto;font-family:'DM Mono',monospace;font-size:13px;line-height:1.55;margin:0}
.detail h2{font-family:'DM Mono',monospace;font-size:22px;word-break:break-all}
.section{background:var(--card);border:1px solid #e7e5e0;border-radius:12px;padding:18px 22px;margin-bottom:16px}
.section h3{margin:0 0 10px;font-size:13px;text-transform:uppercase;letter-spacing:1px;color:var(--orange);font-weight:800}
.section p{margin:0;line-height:1.65}
.section code{background:var(--orange-soft);border:1px solid var(--orange-line);padding:1px 6px;border-radius:6px;font-family:'DM Mono',monospace;font-size:12.5px;color:#b4451f}
table.props{width:100%;border-collapse:separate;border-spacing:0;font-size:13.5px}
table.props th{text-align:left;background:var(--orange-soft);color:#b4451f;padding:8px 12px;font-size:12px;text-transform:uppercase;letter-spacing:.5px}
table.props td{padding:8px 12px;border-bottom:1px solid #f0eeea;vertical-align:top}
table.props td.p{font-family:'DM Mono',monospace;font-weight:500;white-space:nowrap}
table.props td.v{font-family:'DM Mono',monospace;color:#3b5bab;word-break:break-all}
table.props td.d{color:var(--muted)}
.errbox{background:#fff5f5;border:1px solid #f3c1c1;border-radius:12px;padding:14px 18px;margin-bottom:20px;font-size:13.5px}
.errbox b{color:#c0392b}
.count{font-size:13px;color:var(--muted)}
.backbtn{display:inline-block;margin-bottom:14px;background:var(--orange);color:#fff;border:none;border-radius:8px;padding:8px 16px;font-family:inherit;font-weight:700;font-size:13px;cursor:pointer}
.pv{width:100%;height:320px;border:1px solid #e7e5e0;border-radius:10px;background:#fff}
.pvbar{display:flex;gap:10px;align-items:center;margin-bottom:10px}
.pvbtn{background:#fff;border:1px solid #e7e5e0;border-radius:8px;padding:5px 12px;font-family:inherit;font-size:12px;cursor:pointer;font-weight:700}
.pvbtn.on{background:var(--orange);color:#fff;border-color:var(--orange)}

.addbtn{display:block;margin:0 18px 14px;width:calc(100% - 36px);background:var(--orange);color:#fff;border:none;border-radius:8px;padding:9px 0;font-family:inherit;font-weight:800;font-size:13px;cursor:pointer}
.addbtn:hover{background:#d14a20}
.delbtn{background:#fff;border:1px solid #f3c1c1;color:#c0392b;border-radius:8px;padding:5px 12px;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;margin-left:10px}
.delbtn:hover{background:#c0392b;color:#fff;border-color:#c0392b}
.customtag{background:#eefaf0;border:1px solid #bfe8c8;color:#1d7a35;border-radius:10px;padding:1px 8px;font-size:11px}
.modal-bg{position:fixed;inset:0;background:rgba(15,17,23,.6);display:none;align-items:flex-start;justify-content:center;z-index:99;padding:40px 16px;overflow-y:auto}
.modal-bg.open{display:flex}
.modal{background:#fff;border-radius:14px;max-width:760px;width:100%;padding:24px 28px}
.modal h2{margin:0 0 4px;font-size:20px;font-weight:800}
.modal .mdesc{font-size:13px;color:var(--muted);margin:0 0 14px}
.modal textarea{width:100%;min-height:190px;font-family:'DM Mono',monospace;font-size:13px;border:1px solid #e7e5e0;border-radius:10px;padding:12px;resize:vertical;background:#0f1117;color:#e5e9f0;line-height:1.55}
.modal textarea:focus{outline:none;border-color:var(--orange)}
.modal select{font-family:inherit;font-size:13px;padding:7px 10px;border-radius:8px;border:1px solid #e7e5e0;margin-top:10px}
.lint{margin-top:12px;border-radius:10px;padding:12px 14px;font-size:13px;display:none}
.lint.err{display:block;background:#fff5f5;border:1px solid #f3c1c1}
.lint.warn{display:block;background:#fff9ec;border:1px solid #f0dcae}
.lint.ok{display:block;background:#eefaf0;border:1px solid #bfe8c8;color:#1d7a35;font-weight:700}
.lint ul{margin:6px 0 0;padding-left:20px}
.lint .e{color:#c0392b}.lint .w{color:#9a6b00}
.mrow{display:flex;gap:10px;justify-content:flex-end;margin-top:16px}
.mbtn{border:none;border-radius:8px;padding:9px 18px;font-family:inherit;font-weight:800;font-size:13px;cursor:pointer}
.mbtn.save{background:var(--orange);color:#fff}
.mbtn.save:disabled{background:#e0ddd7;color:#9a968e;cursor:not-allowed}
.mbtn.cancel{background:#f0eeea;color:#555}

@media(max-width:900px){.app{flex-direction:column}.side{width:100%;height:auto;position:static}.main{padding:18px}}
</style>
</head>
<body>
<div class="app">
  <div class="side">
    <h1>Bizee KB <span>CSS Library</span></h1>
    <div class="sub" id="stats"></div>
    <input id="q" placeholder="Search selectors or properties...">
    <button class="addbtn" id="addRuleBtn">＋ Add New Rule</button>
    <div id="nav"></div>
  </div>
  <div class="main" id="main"></div>
</div>

<div class="modal-bg" id="modalbg">
  <div class="modal">
    <h2>Add a new rule</h2>
    <p class="mdesc">Paste one or more CSS rules. They're checked live — errors block saving, warnings don't.</p>
    <textarea id="addcss" placeholder=".my-new-class {&#10;  color: #e8562a;&#10;  font-weight: 700;&#10;}" spellcheck="false"></textarea>
    <div><select id="addcat"></select></div>
    <div class="lint" id="lintbox"></div>
    <div class="mrow"><button class="mbtn cancel" id="mcancel">Cancel</button><button class="mbtn save" id="msave" disabled>Add to Library</button></div>
  </div>
</div>

